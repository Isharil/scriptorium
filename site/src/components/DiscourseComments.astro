---
// Affiche les commentaires Discourse liés à une ressource.
// Props :
//   discourse_thread_id — ID du sujet Discourse (optionnel)
//   titre               — Titre de la ressource (pour le bouton "Ouvrir une discussion")
import { getTopic } from '../lib/discourse.js';

interface Props {
  discourse_thread_id?: string | number | null;
  titre?: string;
}

const { discourse_thread_id, titre = '' } = Astro.props;

const DISCOURSE_URL = (import.meta.env.DISCOURSE_URL ?? '').replace(/\/$/, '');
// Slug de la catégorie "Ressources & Sources" dans Discourse (à adapter)
const CATEGORY_SLUG = 'ressources-sources';

let topic: any = null;
if (discourse_thread_id) {
  try {
    topic = await getTopic(discourse_thread_id);
  } catch (err: any) {
    // Ne pas faire planter la page si Discourse est inaccessible
    console.error('[DiscourseComments]', err.message);
  }
}

// Posts : on ignore le 1er (= description de la ressource elle-même)
const posts     = topic?.post_stream?.posts?.slice(1) ?? [];
const postCount = Math.max(0, (topic?.posts_count ?? 1) - 1);
const viewCount = topic?.views ?? 0;
const topicSlug = topic?.slug ?? '';
const topicUrl  = topic ? `${DISCOURSE_URL}/t/${topicSlug}/${discourse_thread_id}` : '';
---

<section class="dc-section">
  {topic ? (
    <>
      <h2 class="dc-title">
        Discussion
        <span class="dc-meta">
          {postCount} réponse{postCount !== 1 ? 's' : ''} · {viewCount} vue{viewCount !== 1 ? 's' : ''}
        </span>
      </h2>

      {posts.length === 0 ? (
        <p class="dc-empty">Pas encore de réponse. Soyez le premier à réagir !</p>
      ) : (
        <ol class="dc-posts">
          {posts.slice(0, 10).map((post: any) => (
            <li class="dc-post">
              <div class="dc-post-header">
                {post.avatar_template && (
                  <img
                    class="dc-avatar"
                    src={post.avatar_template.replace('{size}', '40')}
                    alt={post.username}
                    width="32" height="32"
                    loading="lazy"
                  />
                )}
                <strong class="dc-username">{post.username}</strong>
                <time class="dc-date" datetime={post.created_at}>
                  {new Date(post.created_at).toLocaleDateString('fr-FR', {
                    day: 'numeric', month: 'short', year: 'numeric',
                  })}
                </time>
              </div>
              <div class="dc-cooked" set:html={post.cooked} />
            </li>
          ))}
        </ol>
      )}

      {postCount > 10 && (
        <p class="dc-more">
          <a href={topicUrl} target="_blank" rel="noopener noreferrer">
            Voir les {postCount - 10} autres réponses sur Discourse →
          </a>
        </p>
      )}

      <a class="dc-btn" href={topicUrl} target="_blank" rel="noopener noreferrer">
        Répondre sur Discourse
      </a>
    </>
  ) : (
    <div class="dc-no-thread">
      <p class="dc-empty">Pas encore de discussion pour cette ressource.</p>
      <a
        class="dc-btn"
        href={`${DISCOURSE_URL}/c/${CATEGORY_SLUG}`}
        target="_blank" rel="noopener noreferrer"
      >
        Ouvrir une discussion sur Discourse
      </a>
    </div>
  )}
</section>

<style>
  .dc-section {
    margin-top: 3rem;
    border-top: 0.5px solid #d4c9b0;
    padding-top: 2rem;
  }

  .dc-title {
    font-size: 1.1rem;
    margin: 0 0 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    color: #1a1a1a;
  }

  .dc-meta {
    font-size: 0.8rem;
    font-weight: 400;
    color: #9a9a9a;
  }

  .dc-empty {
    color: #6a6a6a;
    font-style: italic;
    margin: 0 0 1.25rem;
  }

  .dc-posts {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .dc-post {
    background: #faf8f4;
    border: 0.5px solid #e8e0cc;
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .dc-post-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .dc-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .dc-username {
    font-size: 0.85rem;
    color: #1a1a1a;
  }

  .dc-date {
    font-size: 0.75rem;
    color: #9a9a9a;
    margin-left: auto;
  }

  .dc-cooked {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #2a2a2a;
  }

  .dc-cooked :global(p)              { margin: 0 0 0.5rem; }
  .dc-cooked :global(p:last-child)   { margin-bottom: 0; }
  .dc-cooked :global(a)              { color: #8b6914; }
  .dc-cooked :global(blockquote) {
    border-left: 3px solid #d4c9b0;
    margin: 0.5rem 0;
    padding: 0.25rem 0.75rem;
    color: #6a6a6a;
    font-style: italic;
  }
  .dc-cooked :global(code) {
    font-size: 0.8rem;
    background: #f0ece0;
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  .dc-more {
    font-size: 0.8rem;
    margin: 0 0 1rem;
  }

  .dc-more a {
    color: #8b6914;
    text-decoration: none;
  }

  .dc-btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.85rem;
    font-family: inherit;
    transition: background 0.15s;
  }

  .dc-btn:hover { background: #8b6914; }

  .dc-no-thread { padding: 0.5rem 0; }
</style>
