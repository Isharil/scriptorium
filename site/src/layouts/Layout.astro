---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Scriptorium', description = 'Plateforme communautaire de ressources médiévales' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/ressources', label: 'Ressources' },
  { href: '/tutoriels',  label: 'Tutoriels'  },
  { href: '/boutiques',  label: 'Boutiques'  },
  { href: '/carte',      label: 'Carte'      },
  { href: '/forum',      label: 'Forum'      },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title === 'Scriptorium' ? 'Scriptorium' : `${title} — Scriptorium`}</title>
  </head>

  <body>
    <header>
      <div class="header-inner">

        <!-- Logo -->
        <a href="/" class="logo" aria-label="Scriptorium — accueil">
          <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="logo-text">Scriptorium</span>
        </a>

        <!-- Navigation principale -->
        <nav aria-label="Navigation principale">
          <ul>
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class:list={['nav-link', { active: currentPath.startsWith(href) }]}
                  aria-current={currentPath.startsWith(href) ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Barre de recherche -->
        <form class="search-form" action="/recherche" role="search">
          <label for="search" class="sr-only">Rechercher</label>
          <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
          <input
            id="search"
            type="search"
            name="q"
            placeholder="Rechercher une ressource…"
            autocomplete="off"
          />
        </form>

        <!-- CTA -->
        <a href="/rejoindre" class="btn-rejoindre">Rejoindre</a>

        <!-- Menu mobile (burger) -->
        <button class="burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>

      </div>

      <!-- Menu mobile -->
      <div id="mobile-menu" class="mobile-menu" hidden>
        <nav aria-label="Navigation mobile">
          <ul>
            {navLinks.map(({ href, label }) => (
              <li>
                <a href={href} class:list={['nav-link', { active: currentPath.startsWith(href) }]}>
                  {label}
                </a>
              </li>
            ))}
            <li><a href="/rejoindre" class="nav-link">Rejoindre</a></li>
          </ul>
        </nav>
        <form class="search-form mobile-search" action="/recherche" role="search">
          <label for="search-mobile" class="sr-only">Rechercher</label>
          <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
          <input id="search-mobile" type="search" name="q" placeholder="Rechercher…" autocomplete="off" />
        </form>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <a href="/" class="footer-logo">Scriptorium</a>
        <nav aria-label="Navigation pied de page">
          <ul>
            {navLinks.map(({ href, label }) => (
              <li><a href={href}>{label}</a></li>
            ))}
          </ul>
        </nav>
        <p class="footer-copy">
          Ressources médiévales libres &amp; vérifiées par la communauté.
        </p>
      </div>
    </footer>

    <script>
      // Burger menu toggle
      const burger = document.querySelector('.burger') as HTMLButtonElement | null;
      const mobileMenu = document.getElementById('mobile-menu');

      burger?.addEventListener('click', () => {
        const isOpen = burger.getAttribute('aria-expanded') === 'true';
        burger.setAttribute('aria-expanded', String(!isOpen));
        burger.setAttribute('aria-label', isOpen ? 'Ouvrir le menu' : 'Fermer le menu');
        if (mobileMenu) mobileMenu.hidden = isOpen;
      });
    </script>
  </body>
</html>

<style>
  /* ── Reset minimal ───────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 16px;
    color: #1a1a1a;
    background: #fff;
    min-height: 100vh;
  }

  /* ── Utilitaires ─────────────────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 0.5px solid #d4c9b0;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ── Logo ────────────────────────────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #1a1a1a;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 22px;
    height: 22px;
    color: #8b6914;
  }

  .logo-text {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #1a1a1a;
  }

  /* ── Nav principale ──────────────────────────────────────────────────────── */
  nav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .nav-link {
    display: block;
    padding: 0.35rem 0.65rem;
    text-decoration: none;
    font-size: 0.875rem;
    color: #4a4a4a;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #1a1a1a;
    background: #f5f0e8;
  }

  .nav-link.active {
    color: #8b6914;
    font-weight: 600;
  }

  /* ── Recherche ───────────────────────────────────────────────────────────── */
  .search-form {
    flex: 1;
    max-width: 280px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0.6rem;
    width: 14px;
    height: 14px;
    color: #9a9a9a;
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-form input {
    width: 100%;
    padding: 0.4rem 0.75rem 0.4rem 2rem;
    font-size: 0.8rem;
    font-family: inherit;
    border: 0.5px solid #d4c9b0;
    border-radius: 4px;
    background: #faf8f4;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .search-form input::placeholder { color: #aaa; }

  .search-form input:focus {
    border-color: #8b6914;
    background: #fff;
  }

  /* ── Bouton Rejoindre ────────────────────────────────────────────────────── */
  .btn-rejoindre {
    flex-shrink: 0;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-family: inherit;
    text-decoration: none;
    color: #fff;
    background: #1a1a1a;
    border: 0.5px solid #1a1a1a;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .btn-rejoindre:hover {
    background: #8b6914;
    border-color: #8b6914;
  }

  /* ── Burger ──────────────────────────────────────────────────────────────── */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: 0.5px solid #d4c9b0;
    border-radius: 4px;
    cursor: pointer;
    margin-left: auto;
    flex-shrink: 0;
  }

  .burger span {
    display: block;
    height: 1px;
    background: #1a1a1a;
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* ── Menu mobile ─────────────────────────────────────────────────────────── */
  .mobile-menu {
    border-top: 0.5px solid #d4c9b0;
    padding: 1rem 1.5rem;
    background: #fff;
  }

  .mobile-menu ul {
    flex-direction: column;
    gap: 0;
  }

  .mobile-menu .nav-link {
    padding: 0.6rem 0;
    border-bottom: 0.5px solid #f0ece0;
    border-radius: 0;
    font-size: 0.9rem;
  }

  .mobile-search {
    margin-top: 1rem;
    max-width: 100%;
  }

  /* ── Main ────────────────────────────────────────────────────────────────── */
  main {
    min-height: calc(100vh - 56px - 80px);
  }

  /* ── Footer ──────────────────────────────────────────────────────────────── */
  footer {
    border-top: 0.5px solid #d4c9b0;
    padding: 2rem 1.5rem;
    background: #faf8f4;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-logo {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
  }

  footer nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  footer nav a {
    font-size: 0.8rem;
    color: #6a6a6a;
    text-decoration: none;
    padding: 0.2rem 0.5rem;
  }

  footer nav a:hover { color: #1a1a1a; }

  .footer-copy {
    font-size: 0.75rem;
    color: #9a9a9a;
    margin: 0;
    margin-left: auto;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .header-inner > nav,
    .search-form,
    .btn-rejoindre {
      display: none;
    }

    .burger {
      display: flex;
    }

    .footer-copy {
      margin-left: 0;
    }
  }
</style>