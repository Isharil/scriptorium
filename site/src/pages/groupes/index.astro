---
import Layout from '../../layouts/Layout.astro';
import { getGroupes } from '../../lib/nocodb.js';

let groupes = [];
try { groupes = await getGroupes(); }
catch (e) { console.warn('[groupes]', e.message); }

const params  = Astro.url.searchParams;
const qQ      = params.get('q')      ?? '';
const qType   = params.get('type')   ?? '';
const qPeriode = params.get('periode') ?? '';
const qRegion = params.get('region') ?? '';

const TYPES = [
  { value: 'troupe_reconstitution', label: 'Troupe de reconstitution' },
  { value: 'musique',               label: 'Groupe de musique'         },
  { value: 'theatre_spectacle',     label: 'Théâtre / Spectacle'       },
  { value: 'confrerie',             label: 'Confrérie'                 },
  { value: 'association',           label: 'Association'               },
];

const PERIODES = [
  { value: 'tout_MA',     label: 'Tout le Moyen Âge' },
  { value: 'haut_MA',     label: 'Haut Moyen Âge'    },
  { value: 'Xe_XIe',      label: 'Xe – XIe s.'        },
  { value: 'XIIe_XIIIe',  label: 'XIIe – XIIIe s.'   },
  { value: 'XIVe',        label: 'XIVe s.'            },
  { value: 'XVe',         label: 'XVe s.'             },
];

const REGIONS = [
  { value: 'france',      label: 'France'           },
  { value: 'empire',      label: 'Empire germanique' },
  { value: 'italie',      label: 'Italie'           },
  { value: 'iberique',    label: 'Péninsule ibérique'},
  { value: 'angleterre',  label: 'Îles britanniques' },
  { value: 'scandinavie', label: 'Scandinavie'       },
  { value: 'byzance',     label: 'Byzance'           },
];

function matchMulti(field, value) {
  if (!value) return true;
  if (!field)  return false;
  return String(field).split(',').map(v => v.trim()).includes(value);
}

const filtres = groupes.filter(g => {
  if (qType   && g.type    !== qType)              return false;
  if (qPeriode && !matchMulti(g.periodes, qPeriode)) return false;
  if (qRegion  && !matchMulti(g.regions,  qRegion))  return false;
  if (qQ) {
    const hay = `${g.nom} ${g.description} ${g.ville} ${g.specialites}`.toLowerCase();
    if (!hay.includes(qQ.toLowerCase())) return false;
  }
  return true;
});

const hasFilters = qQ || qType || qPeriode || qRegion;

function buildUrl(ov) {
  const p = new URLSearchParams({
    ...(qQ      ? { q: qQ }           : {}),
    ...(qType   ? { type: qType }     : {}),
    ...(qPeriode ? { periode: qPeriode } : {}),
    ...(qRegion ? { region: qRegion } : {}),
    ...ov,
  });
  for (const [k, v] of [...p.entries()]) { if (!v) p.delete(k); }
  const qs = p.toString();
  return `/groupes${qs ? '?' + qs : ''}`;
}

const typeLabel = v => TYPES.find(t => t.value === v)?.label ?? v;

function parseMulti(val, map) {
  if (!val) return [];
  return String(val).split(',').map(v => map.find(m => m.value === v.trim())?.label ?? v.trim());
}
---

<Layout title="Groupes" description="Troupes de reconstitution, groupes de musique médiévale, compagnies de spectacle et associations.">

  <div class="page-head">
    <div class="page-head-inner">
      <div>
        <h1>Groupes</h1>
        <p class="page-desc">
          {filtres.length} groupe{filtres.length !== 1 ? 's' : ''}
          {hasFilters ? ' trouvé·s' : ' référencés'}
        </p>
      </div>
      <a href="https://forum.scriptorium.fr" target="_blank" rel="noopener" class="btn-primary">
        + Référencer un groupe
      </a>
    </div>
  </div>

  <div class="page-body">

    <!-- Filtres -->
    <aside class="filtres">
      <form method="get" action="/groupes">

        <div class="filtre-group">
          <label for="q" class="filtre-label">Recherche</label>
          <div class="search-wrap">
            <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/></svg>
            <input id="q" type="search" name="q" value={qQ} placeholder="Nom, spécialité…" autocomplete="off" />
          </div>
        </div>

        <div class="filtre-group">
          <label class="filtre-label">Type</label>
          <div class="chip-group">
            <a href={buildUrl({ type: '' })} class:list={['chip', { 'chip-active': !qType }]}>Tous</a>
            {TYPES.map(t => (
              <a href={buildUrl({ type: t.value })} class:list={['chip', { 'chip-active': qType === t.value }]}>{t.label}</a>
            ))}
          </div>
        </div>

        <div class="filtre-group">
          <label for="periode" class="filtre-label">Période</label>
          <select id="periode" name="periode" onchange="this.form.submit()" class="field-select">
            <option value="">Toutes les périodes</option>
            {PERIODES.map(p => <option value={p.value} selected={qPeriode === p.value}>{p.label}</option>)}
          </select>
        </div>

        <div class="filtre-group">
          <label for="region" class="filtre-label">Région historique</label>
          <select id="region" name="region" onchange="this.form.submit()" class="field-select">
            <option value="">Toutes les régions</option>
            {REGIONS.map(r => <option value={r.value} selected={qRegion === r.value}>{r.label}</option>)}
          </select>
        </div>

        {hasFilters && <a href="/groupes" class="btn-reset">Réinitialiser</a>}
      </form>
    </aside>

    <!-- Grille -->
    <section class="groupes-wrap">
      <div class="sort-bar">
        <span class="sort-count">{filtres.length} résultat{filtres.length !== 1 ? 's' : ''}</span>
      </div>

      {filtres.length === 0 ? (
        <div class="empty-state">
          <p>Aucun groupe ne correspond à ces critères.</p>
          {hasFilters && <a href="/groupes" class="link-reset">Effacer les filtres</a>}
        </div>
      ) : (
        <ol class="groupes-grid">
          {filtres.map(g => {
            const periodes = parseMulti(g.periodes, PERIODES).slice(0, 2);
            const regions  = parseMulti(g.regions,  REGIONS).slice(0, 2);
            return (
              <li>
                <a href={`/groupes/${g.Id}`} class="groupe-card">
                  <div class="gc-header">
                    <span class="gc-nom">{g.nom}</span>
                  </div>

                  {g.type && (
                    <div class="gc-type">{typeLabel(g.type)}</div>
                  )}

                  {g.description && (
                    <p class="gc-desc">{g.description.slice(0, 130)}{g.description.length > 130 ? '…' : ''}</p>
                  )}

                  <div class="gc-footer">
                    <div class="gc-tags">
                      {periodes.map(p => <span class="tag tag-periode">{p}</span>)}
                      {regions.map(r  => <span class="tag tag-region">{r}</span>)}
                    </div>
                    {g.ville && (
                      <span class="gc-lieu">{[g.ville, g.pays].filter(Boolean).join(', ')}</span>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </section>
  </div>
</Layout>

<style>
  .page-head { background: #faf8f4; border-bottom: 0.5px solid #d4c9b0; padding: 2rem 1.5rem; }
  .page-head-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  h1 { margin: 0 0 .25rem; font-size: 1.75rem; font-family: 'Georgia', serif; }
  .page-desc { margin: 0; font-size: .875rem; color: #7a7a7a; }
  .btn-primary { display: inline-block; padding: .5rem 1rem; font-size: .8rem; font-family: inherit; text-decoration: none; color: #fff; background: #1a1a1a; border: 0.5px solid #1a1a1a; border-radius: 4px; transition: background .15s; white-space: nowrap; }
  .btn-primary:hover { background: #8b6914; border-color: #8b6914; }

  .page-body { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; display: grid; grid-template-columns: 220px 1fr; gap: 3rem; align-items: start; }

  /* Filtres */
  .filtres { position: sticky; top: 72px; display: flex; flex-direction: column; }
  .filtre-group { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 1.25rem; }
  .filtre-group:first-child { margin-top: 0; }
  .filtre-label { font-size: .7rem; font-family: sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; color: #7a7a7a; }
  .search-wrap { position: relative; }
  .search-icon { position: absolute; left: .6rem; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: #9a9a9a; pointer-events: none; }
  .search-wrap input { width: 100%; padding: .4rem .6rem .4rem 2rem; font-size: .8rem; font-family: inherit; border: 0.5px solid #d4c9b0; border-radius: 4px; background: #faf8f4; outline: none; }
  .search-wrap input:focus { border-color: #8b6914; }
  .chip-group { display: flex; flex-wrap: wrap; gap: .3rem; }
  .chip { display: inline-block; padding: .18rem .5rem; font-size: .7rem; font-family: sans-serif; border: 0.5px solid #d4c9b0; border-radius: 3px; color: #4a4a4a; text-decoration: none; background: #fff; transition: border-color .12s, color .12s; }
  .chip:hover { border-color: #8b6914; color: #8b6914; }
  .chip-active { background: #8b6914 !important; border-color: #8b6914 !important; color: #fff !important; }
  .field-select { width: 100%; padding: .4rem .6rem; font-size: .8rem; font-family: inherit; border: 0.5px solid #d4c9b0; border-radius: 4px; background: #faf8f4; outline: none; }
  .field-select:focus { border-color: #8b6914; }
  .btn-reset { display: block; padding: .4rem; font-size: .78rem; text-align: center; color: #8b3a1a; text-decoration: none; border: 0.5px dashed #d4b0b0; border-radius: 4px; background: #fff8f8; }

  /* Grille */
  .sort-bar { display: flex; justify-content: flex-end; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 0.5px solid #eee8d8; }
  .sort-count { font-size: .78rem; color: #9a9a9a; }
  .groupes-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; align-items: start; }

  /* Carte groupe */
  .groupe-card { display: flex; flex-direction: column; gap: .5rem; padding: 1.25rem; border: 0.5px solid #d4c9b0; border-radius: 6px; background: #fff; text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .15s; }
  .groupe-card:hover { border-color: #8b6914; box-shadow: 0 2px 12px rgba(139,105,20,.08); }
  .gc-header { display: flex; align-items: flex-start; justify-content: space-between; }
  .gc-nom { font-size: 1rem; font-weight: 600; color: #1a1a1a; line-height: 1.3; }
  .gc-type { font-size: .72rem; font-family: sans-serif; background: #f0eaff; color: #3a1a6a; border: 0.5px solid #c9b8e8; border-radius: 3px; padding: .1rem .4rem; align-self: flex-start; }
  .gc-desc { margin: 0; font-size: .82rem; color: #5a5a5a; line-height: 1.55; flex: 1; }
  .gc-footer { display: flex; align-items: flex-end; justify-content: space-between; gap: .5rem; flex-wrap: wrap; margin-top: auto; }
  .gc-tags { display: flex; flex-wrap: wrap; gap: .3rem; }
  .tag { font-size: .68rem; font-family: sans-serif; border-radius: 3px; padding: .1rem .35rem; border: 0.5px solid; }
  .tag-periode { background: #f5f0e8; color: #5a4a1a; border-color: #d4c9b0; }
  .tag-region  { background: #e8f0f5; color: #1a3a5a; border-color: #b0c8d4; }
  .gc-lieu { font-size: .72rem; color: #9a9a9a; white-space: nowrap; }

  .empty-state { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem 2rem; text-align: center; color: #7a7a7a; border: 0.5px dashed #d4c9b0; border-radius: 6px; }
  .link-reset { font-size: .8rem; color: #8b6914; text-decoration: none; }

  @media (max-width: 900px) { .page-body { grid-template-columns: 1fr; } .filtres { position: static; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); } }
  @media (max-width: 600px) { .page-head { padding: 1.25rem 1rem; } .page-body { padding: 1.25rem 1rem; } .groupes-grid { grid-template-columns: 1fr; } .filtres { grid-template-columns: 1fr; } }
</style>
