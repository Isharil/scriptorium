---
import Layout from '../../layouts/Layout.astro';
import { getBoutiques } from '../../lib/nocodb.js';

let boutiques = [];
try { boutiques = await getBoutiques(); }
catch (e) { console.warn('[boutiques]', e.message); }

const params    = Astro.url.searchParams;
const qQ        = params.get('q')          ?? '';
const qSpecial  = params.get('specialite') ?? '';
const qType     = params.get('type')       ?? '';
const qPays     = params.get('pays')       ?? '';
const qLiv      = params.get('livraison')  ?? '';

function matchMulti(field, value) {
  if (!value) return true;
  if (!field)  return false;
  return String(field).split(',').map(v => v.trim()).includes(value);
}

const filtrees = boutiques.filter(b => {
  if (qSpecial && !matchMulti(b.specialites, qSpecial)) return false;
  if (qType    && b.type !== qType)                    return false;
  if (qPays    && b.pays?.toLowerCase() !== qPays.toLowerCase()) return false;
  if (qLiv     && !b.livraison_europe)                 return false;
  if (qQ) {
    const hay = `${b.nom} ${b.description} ${b.ville} ${b.pays}`.toLowerCase();
    if (!hay.includes(qQ.toLowerCase())) return false;
  }
  return true;
});

const hasFilters = qQ || qSpecial || qType || qPays || qLiv;

function buildUrl(ov) {
  const p = new URLSearchParams({
    ...(qQ       ? { q: qQ }               : {}),
    ...(qSpecial ? { specialite: qSpecial } : {}),
    ...(qType    ? { type: qType }          : {}),
    ...(qPays    ? { pays: qPays }          : {}),
    ...(qLiv     ? { livraison: qLiv }      : {}),
    ...ov,
  });
  for (const [k, v] of [...p.entries()]) { if (!v) p.delete(k); }
  const qs = p.toString();
  return `/boutiques${qs ? '?' + qs : ''}`;
}

const SPECIALITES = [
  { value: 'textiles',    label: 'Textiles'     },
  { value: 'armes',       label: 'Armes'        },
  { value: 'armures',     label: 'Armures'      },
  { value: 'maroquinerie',label: 'Maroquinerie' },
  { value: 'bijoux',      label: 'Bijoux'       },
  { value: 'forge',       label: 'Forge'        },
  { value: 'mercerie',    label: 'Mercerie'     },
  { value: 'livres',      label: 'Livres'       },
];

const TYPES = [
  { value: 'boutique_en_ligne',  label: 'En ligne'       },
  { value: 'atelier_physique',   label: 'Atelier'        },
  { value: 'les_deux',           label: 'En ligne + atelier' },
  { value: 'marche_uniquement',  label: 'Marchés only'   },
];

function noteEtoiles(note) {
  if (!note) return '';
  const n = Math.round(Number(note));
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}

function parseMultiLabel(val, map) {
  if (!val) return [];
  return String(val).split(',').map(v => map[v.trim()] ?? v.trim());
}

const SPEC_LABELS = {
  textiles:'Textiles', armes:'Armes', armures:'Armures', maroquinerie:'Maroquinerie',
  bijoux:'Bijoux', forge:'Forge', mercerie:'Mercerie', livres:'Livres', autre:'Autre',
};
---

<Layout title="Boutiques" description="Boutiques médiévales vérifiées : textiles, armes, armures, forge…">

  <div class="page-head">
    <div class="page-head-inner">
      <div>
        <h1>Boutiques</h1>
        <p class="page-desc">{filtrees.length} boutique{filtrees.length !== 1 ? 's' : ''}{hasFilters ? ' trouvée·s' : ' référencées'}</p>
      </div>
      <div class="head-actions">
        <a href="/carte?vue=boutiques" class="btn-secondary">🗺 Voir la carte</a>
        <a href="/soumettre?type=boutique" class="btn-primary">+ Ajouter une boutique</a>
      </div>
    </div>
  </div>

  <div class="page-body">

    <!-- Filtres -->
    <aside class="filtres">
      <form method="get" action="/boutiques">

        <div class="filtre-group">
          <label for="q" class="filtre-label">Recherche</label>
          <div class="search-wrap">
            <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/></svg>
            <input id="q" type="search" name="q" value={qQ} placeholder="Nom, ville…" autocomplete="off" />
          </div>
        </div>

        <div class="filtre-group">
          <label class="filtre-label">Spécialité</label>
          <div class="chip-group">
            <a href={buildUrl({ specialite: '' })} class:list={['chip', { 'chip-active': !qSpecial }]}>Toutes</a>
            {SPECIALITES.map(s => (
              <a href={buildUrl({ specialite: s.value })} class:list={['chip', { 'chip-active': qSpecial === s.value }]}>{s.label}</a>
            ))}
          </div>
        </div>

        <div class="filtre-group">
          <label for="type" class="filtre-label">Type</label>
          <select id="type" name="type" onchange="this.form.submit()">
            <option value="">Tous les types</option>
            {TYPES.map(t => <option value={t.value} selected={qType === t.value}>{t.label}</option>)}
          </select>
        </div>

        <div class="filtre-group">
          <label class="filtre-label">Options</label>
          <label class="toggle-label">
            <input type="checkbox" name="livraison" value="1" checked={!!qLiv} onchange="this.form.submit()" />
            Livraison Europe
          </label>
        </div>

        {hasFilters && <a href="/boutiques" class="btn-reset">Réinitialiser</a>}
      </form>
    </aside>

    <!-- Grille -->
    <section class="boutiques-wrap">
      <div class="sort-bar">
        <span class="sort-count">{filtrees.length} résultat{filtrees.length !== 1 ? 's' : ''}</span>
      </div>

      {filtrees.length === 0 ? (
        <div class="empty-state">
          <p>Aucune boutique ne correspond à ces critères.</p>
          <a href="/boutiques" class="link-reset">Effacer les filtres</a>
        </div>
      ) : (
        <ol class="boutiques-grid">
          {filtrees.map(b => {
            const specs = parseMultiLabel(b.specialites, SPEC_LABELS).slice(0, 3);
            return (
              <li>
                <a href={`/boutiques/${b.Id}`} class="boutique-card">
                  <div class="bc-header">
                    <span class="bc-nom">{b.nom}</span>
                    {b.lien_verifie && <span class="badge-verifie" title="Lien vérifié">✓</span>}
                  </div>

                  <div class="bc-meta">
                    {b.type && <span class="bc-type">{TYPES.find(t => t.value === b.type)?.label ?? b.type}</span>}
                    {b.ville && <span class="bc-lieu">{[b.ville, b.pays].filter(Boolean).join(', ')}</span>}
                  </div>

                  {b.description && (
                    <p class="bc-desc">{b.description.slice(0, 120)}{b.description.length > 120 ? '…' : ''}</p>
                  )}

                  <div class="bc-footer">
                    <div class="bc-specs">
                      {specs.map(s => <span class="spec-tag">{s}</span>)}
                    </div>
                    <div class="bc-right">
                      {b.note_moyenne && (
                        <span class="bc-note" title={`Note : ${b.note_moyenne}/5`}>
                          <span class="etoiles">{noteEtoiles(b.note_moyenne)}</span>
                          <span class="note-val">{Number(b.note_moyenne).toFixed(1)}</span>
                        </span>
                      )}
                      {b.livraison_europe && <span class="badge-liv" title="Livraison Europe">🇪🇺</span>}
                    </div>
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </section>
  </div>
</Layout>

<style>
  .page-head { background: #faf8f4; border-bottom: 0.5px solid #d4c9b0; padding: 2rem 1.5rem; }
  .page-head-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  h1 { margin: 0 0 0.25rem; font-size: 1.75rem; font-family: 'Georgia', serif; }
  .page-desc { margin: 0; font-size: 0.875rem; color: #7a7a7a; }
  .head-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn-primary { display: inline-block; padding: 0.5rem 1rem; font-size: 0.8rem; font-family: inherit; text-decoration: none; color: #fff; background: #1a1a1a; border: 0.5px solid #1a1a1a; border-radius: 4px; transition: background .15s, border-color .15s; white-space: nowrap; }
  .btn-primary:hover { background: #8b6914; border-color: #8b6914; }
  .btn-secondary { display: inline-block; padding: 0.5rem 1rem; font-size: 0.8rem; text-decoration: none; color: #1a1a1a; border: 0.5px solid #d4c9b0; border-radius: 4px; transition: border-color .15s; white-space: nowrap; }
  .btn-secondary:hover { border-color: #8b6914; }

  .page-body { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; display: grid; grid-template-columns: 220px 1fr; gap: 3rem; align-items: start; }

  /* Filtres */
  .filtres { position: sticky; top: 72px; display: flex; flex-direction: column; }
  .filtre-group { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 1.25rem; }
  .filtre-group:first-child { margin-top: 0; }
  .filtre-label { font-size: 0.7rem; font-family: sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; color: #7a7a7a; }
  .search-wrap { position: relative; }
  .search-icon { position: absolute; left: .6rem; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: #9a9a9a; pointer-events: none; }
  .search-wrap input { width: 100%; padding: .4rem .6rem .4rem 2rem; font-size: .8rem; font-family: inherit; border: 0.5px solid #d4c9b0; border-radius: 4px; background: #faf8f4; outline: none; }
  .search-wrap input:focus { border-color: #8b6914; }
  .chip-group { display: flex; flex-wrap: wrap; gap: .3rem; }
  .chip { display: inline-block; padding: .18rem .5rem; font-size: .7rem; font-family: sans-serif; border: 0.5px solid #d4c9b0; border-radius: 3px; color: #4a4a4a; text-decoration: none; background: #fff; transition: border-color .12s, color .12s; }
  .chip:hover { border-color: #8b6914; color: #8b6914; }
  .chip-active { background: #8b6914; border-color: #8b6914; color: #fff; }
  select { width: 100%; padding: .4rem .6rem; font-size: .8rem; font-family: inherit; border: 0.5px solid #d4c9b0; border-radius: 4px; background: #faf8f4; outline: none; }
  select:focus { border-color: #8b6914; }
  .toggle-label { display: flex; align-items: center; gap: .5rem; font-size: .85rem; color: #3a3a3a; cursor: pointer; }
  .btn-reset { display: block; padding: .4rem; font-size: .78rem; text-align: center; color: #8b3a1a; text-decoration: none; border: 0.5px dashed #d4b0b0; border-radius: 4px; background: #fff8f8; }

  /* Grille */
  .sort-bar { display: flex; justify-content: flex-end; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 0.5px solid #eee8d8; }
  .sort-count { font-size: .78rem; color: #9a9a9a; }
  .boutiques-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; align-items: start; }

  /* Carte boutique */
  .boutique-card { display: flex; flex-direction: column; gap: .6rem; padding: 1.25rem; border: 0.5px solid #d4c9b0; border-radius: 6px; background: #fff; text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .15s; }
  .boutique-card:hover { border-color: #8b6914; box-shadow: 0 2px 12px rgba(139,105,20,.08); }
  .bc-header { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; }
  .bc-nom { font-size: 1rem; font-weight: 600; color: #1a1a1a; line-height: 1.3; }
  .badge-verifie { font-size: .72rem; background: #e8f5e8; color: #1a4a2a; border: 0.5px solid #b0d4b0; border-radius: 3px; padding: .1rem .4rem; flex-shrink: 0; }
  .bc-meta { display: flex; flex-wrap: wrap; align-items: center; gap: .5rem; }
  .bc-type { font-size: .72rem; font-family: sans-serif; background: #f5f0e8; color: #5a4a1a; border: 0.5px solid #d4c9b0; border-radius: 3px; padding: .1rem .4rem; }
  .bc-lieu { font-size: .78rem; color: #7a7a7a; }
  .bc-desc { margin: 0; font-size: .82rem; color: #5a5a5a; line-height: 1.55; flex: 1; }
  .bc-footer { display: flex; align-items: center; justify-content: space-between; gap: .5rem; margin-top: auto; }
  .bc-specs { display: flex; flex-wrap: wrap; gap: .3rem; }
  .spec-tag { font-size: .68rem; font-family: sans-serif; background: #f5f5f0; color: #6a6a6a; border: 0.5px solid #e0e0d0; border-radius: 3px; padding: .1rem .35rem; }
  .bc-right { display: flex; align-items: center; gap: .5rem; flex-shrink: 0; }
  .bc-note { display: flex; align-items: center; gap: .3rem; font-size: .78rem; }
  .etoiles { color: #8b6914; letter-spacing: -.05em; font-size: .85rem; }
  .note-val { color: #5a5a5a; }
  .badge-liv { font-size: .9rem; }

  .empty-state { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem 2rem; text-align: center; color: #7a7a7a; border: 0.5px dashed #d4c9b0; border-radius: 6px; }
  .link-reset { font-size: .8rem; color: #8b6914; text-decoration: none; }

  @media (max-width: 900px) { .page-body { grid-template-columns: 1fr; } .filtres { position: static; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); } }
  @media (max-width: 600px) { .page-head { padding: 1.25rem 1rem; } .page-body { padding: 1.25rem 1rem; } .boutiques-grid { grid-template-columns: 1fr; } .filtres { grid-template-columns: 1fr; } }
</style>
